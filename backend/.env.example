# Copia questo file in .env e adatta i valori
# cp .env.example .env

# Connessione PostgreSQL
DATABASE_URL=postgresql://fitquest:fitquest@localhost:5432/fitquest

# Segreto JWT — cambia in produzione con una stringa casuale >= 32 caratteri
JWT_SECRET=dev-secret-change-in-production

# Origine CORS (frontend dev server)
CORS_ORIGIN=http://localhost:5173

# Porta del server Express
PORT=3000
